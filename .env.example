# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/suuq_db
# Alternative DB configuration (if using separate vars)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=username
DB_PASSWORD=password
DB_DATABASE=suuq_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com,https://ugasfuad.com,https://www.ugasfuad.com

# Swagger Configuration
SWAGGER_ENABLED=true

# Database Migration
AUTO_MIGRATE=true

# AWS S3 Configuration
S3_ACCESS_KEY_ID=your-aws-access-key
S3_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# Google OAuth Configuration
GOOGLE_WEB_CLIENT_ID=your-google-client-id
# Backward-compatible alias still accepted by the backend if already in use:
# GOOGLE_CLIENT_ID=your-google-client-id
# Required for the POS Google OAuth *redirect* flow (iOS / ITP browsers). The
# ID-token (GIS popup) flow does not need it, but the authorization-code
# exchange in /pos-portal/auth/google/callback does.
GOOGLE_CLIENT_SECRET=your-google-client-secret
# POS Google OAuth redirect flow (top-level flow used on iOS, where WebKit ITP
# breaks the GIS popup). Leave GOOGLE_OAUTH_REDIRECT_URI unset to derive it from
# the request host (<origin>/api/pos-portal/auth/google/callback); set it only to
# pin a single URL. This exact URL must be added as an "Authorized redirect URI"
# on the OAuth client in Google Cloud Console.
# GOOGLE_OAUTH_REDIRECT_URI=https://api.suuq-s.com/api/pos-portal/auth/google/callback
# Comma-separated extra app origins the redirect flow may bounce back to (the
# pos.suuq-s.com / pos.ugasfuad.com / localhost origins are allowed by default).
# POS_GOOGLE_REDIRECT_ALLOWED_ORIGINS=https://pos.example.com

# Rate Limiting Configuration
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# Email Configuration (if using SMTP)
# Map to code's expected keys
EMAIL_HOST=smtp.postmarkapp.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM="Suuq Marketplace <no-reply@suuq.com>"
MARKETING_LEADS_EMAIL=admin@example.com
MARKETING_LEADS_FILE=/var/lib/suuq-backend/marketing-leads.jsonl
MARKETING_LEADS_WEBHOOK_URL=https://example-crm.test/webhooks/marketing-leads
MARKETING_LEADS_WEBHOOK_HEADER_NAME=Authorization
MARKETING_LEADS_WEBHOOK_HEADER_VALUE=Bearer replace-me
MARKETING_LEADS_WEBHOOK_TIMEOUT_MS=5000
ADMIN_URL=https://admin.example.com

# Firebase Configuration (if using Firebase services)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Twilio Verify (server-side secrets only; do not commit real values)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Redis (optional; used for OTP rate limiting if enabled)
# Set REDIS_ENABLED=true and provide REDIS_URL (or host/port) to enable
REDIS_ENABLED=false
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379\n# Ebirr Payment Configuration\nEBIRR_BASE_URL=https://testpayments.ebirr.com\nEBIRR_API_KEY=\nEBIRR_MERCHANT_ID=
