--- seller-workspace.service.ts
+++ seller-workspace.service.ts
@@ -548,4 +549,27 @@
   
       return this.serializeBranchWorkspace(savedBranch, true, 'OPEN');
     }
+
+  async updateBranchWorkspaceServiceFormat(
+    userId: number,
+    branchId: number,
+    dto: UpdateBranchServiceFormatDto,
+  ): Promise<SellerWorkspaceBranchWorkspaceDto> {
+    const branch = await this.sellerWorkspacesRepository.manager.getRepository('branches').findOne({
+      where: { id: branchId, ownerId: userId },
+    });
+
+    if (!branch) {
+      throw new NotFoundException(`Branch workspace with ID ${branchId} not found or you do not have permission.`);
+    }
+
+    const normalizedServiceFormat = assertAllowedSelfServeServiceFormat(
+      dto.serviceFormat,
+      'Branch service format update',
+    );
+
+    await this.sellerWorkspacesRepository.manager.getRepository('branches').update(branchId, { serviceFormat: normalizedServiceFormat });
+    branch.serviceFormat = normalizedServiceFormat;
+    return this.serializeBranchWorkspace(branch, true, 'OPEN');
+  }
 }
