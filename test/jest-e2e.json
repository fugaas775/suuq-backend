{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "detectOpenHandles": true,
  "openHandlesTimeout": 5000,
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "types": ["node", "jest"]
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^file-type$": "<rootDir>/../__mocks__/file-type.ts"
  }
}
